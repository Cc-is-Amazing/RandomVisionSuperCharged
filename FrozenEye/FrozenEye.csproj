<Project Sdk="Godot.NET.Sdk/4.5.1">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <AssemblyName>FrozenEye</AssemblyName>
    <RootNamespace>FrozenEye</RootNamespace>
    <DefaultItemExcludes>packages\**</DefaultItemExcludes>
    <Sts2Path Condition="'$(Sts2Path)' == ''">$([System.IO.Path]::GetFullPath('$(MSBuildProjectDirectory)/../..'))</Sts2Path>
    <Sts2DataDir Condition="'$(Sts2DataDir)' == ''">$(Sts2Path)/data_sts2_windows_x86_64</Sts2DataDir>
    <GodotPath Condition="'$(GodotPath)' == ''"></GodotPath>
    <ModOutputDir>$(Sts2Path)/mods/FrozenEye</ModOutputDir>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="0Harmony">
      <HintPath>$(Sts2DataDir)/0Harmony.dll</HintPath>
    </Reference>
    <Reference Include="GodotSharp">
      <HintPath>$(Sts2DataDir)/GodotSharp.dll</HintPath>
    </Reference>
    <Reference Include="sts2">
      <HintPath>$(Sts2DataDir)/sts2.dll</HintPath>
      <Publicize>PublicizeSts</Publicize>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="BepInEx.AssemblyPublicizer.MSBuild" Version="0.4.3">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="**\*.uid" />
    <AdditionalFiles Remove="**\*.uid" />
    <EmbeddedResource Remove="**\*.uid" />
    <None Remove="**\*.uid" />
  </ItemGroup>

  <ItemGroup>
    <None Include="FrozenEye.json" />
    <None Include="export_presets.cfg" />
    <None Include="icon.svg" />
    <None Include="mod_manifest.json" />
    <None Include="nuget.config" />
    <None Include="project.godot" />
    <None Include="README.md" />
  </ItemGroup>

  <Target Name="CopyToModsFolderOnBuild" AfterTargets="Build">
    <MakeDir Directories="$(ModOutputDir)" />
    <Copy SourceFiles="$(TargetPath)" DestinationFolder="$(ModOutputDir)" />
    <Copy SourceFiles="FrozenEye.json" DestinationFolder="$(ModOutputDir)" />
  </Target>

  <Target
    Name="GodotPublish"
    AfterTargets="Publish"
    Condition="'$(GodotPath)' != '' and Exists('$(GodotPath)') and '$(IsInnerGodotExport)' != 'true'">
    <MakeDir Directories="$(ModOutputDir)" />
    <Exec
      Command="&quot;$(GodotPath)&quot; --headless --export-pack &quot;Windows Desktop&quot; &quot;$(ModOutputDir)/FrozenEye.pck&quot;"
      EnvironmentVariables="IsInnerGodotExport=true;MSBUILDDISABLENODEREUSE=1"
      ContinueOnError="WarnAndContinue" />
  </Target>

  <Target Name="GodotPublishSkipped" AfterTargets="Publish" Condition="'$(GodotPath)' == '' or !Exists('$(GodotPath)')">
    <Message Text="Skipping Godot .pck export because GodotPath is not configured." Importance="high" />
  </Target>
</Project>
